# GitHub Configuration
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxx
GITHUB_OWNER=bdlozano
GITHUB_REPO=pipeline_alm_IA
GITHUB_WEBHOOK_SECRET=your-webhook-secret-key

# LLM Provider Configuration
# Options: anthropic, openai, cohere
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
LLM_MODEL=claude-3-sonnet-20240229
# Alternativa para OpenAI
# LLM_MODEL=gpt-4-turbo

# Agent Configuration
AGENT_CONFIDENCE_THRESHOLD=0.80
AGENT_AUTO_MERGE_THRESHOLD=0.90
AGENT_MAX_RETRIES=3
AGENT_TIMEOUT_MINUTES=60
AGENT_MAX_FILES_CHANGED=5
AGENT_MAX_LINES_CHANGED=500

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/agent.log
LOG_FORMAT=json

# Webhook Configuration
WEBHOOK_PORT=8000
WEBHOOK_HOST=0.0.0.0
WEBHOOK_SECRET=your-secret-key-here

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/self_healing_ci
DATABASE_POOL_SIZE=20

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_PREFIX=self-healing:

# Safety & Security
SAFE_MODE=true
ALLOWED_FILE_PATTERNS=src/**/*.py,tests/**/*.py,config/**/*.yml,requirements.txt
FORBIDDEN_FILE_PATTERNS=.github/workflows/**,docker/**,terraform/**,*.key,*.pem

# Feature Flags
ENABLE_AUTO_MERGE=false
ENABLE_DRAFT_PR=true
ENABLE_AUTO_COMMENT=true
ENABLE_AUDIT_LOG=true

# Monitoring & Observability
SENTRY_DSN=https://xxxxxxxx@sentry.io/xxxxxxxx
DATADOG_API_KEY=xxxxxxxxxx

# Development
DEBUG=false
DEVELOPMENT_MODE=false
